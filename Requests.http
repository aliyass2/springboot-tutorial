### Authentication
### Register (ADMIN)
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "name": "admin",
  "username": "admin",
  "password": "Admin@123",
  "role": "ADMIN"
}

### Register (USER)
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "name": "alice",
  "username": "alice",
  "password": "Alice@123"
}

### Login — copy the returned token into http-client.env.json -> "token"
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "Admin@123"
}

### Software Engineer
### Get All (USER or ADMIN)
GET {{baseUrl}}/api/v1/software-engineer
Authorization: Bearer {{token}}

### Get By Id (USER or ADMIN)
GET {{baseUrl}}/api/v1/software-engineer/1
Authorization: Bearer {{token}}

### Create (ADMIN only)
POST {{baseUrl}}/api/v1/software-engineer
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Nicolas Jackson",
  "techStack": "Java, Node, JS",
  "projectIds": []
}

### Update (ADMIN only)
PUT {{baseUrl}}/api/v1/software-engineer/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "UPDATED",
  "techStack": "Java, Node, JS"
}

### Delete (ADMIN only)
DELETE {{baseUrl}}/api/v1/software-engineer/1
Authorization: Bearer {{token}}

### Projects
### Get All (USER or ADMIN)
GET {{baseUrl}}/api/v1/project
Authorization: Bearer {{token}}

### Get By Id (USER or ADMIN)
GET {{baseUrl}}/api/v1/project/1
Authorization: Bearer {{token}}

### Create (ADMIN only)
POST {{baseUrl}}/api/v1/project
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Evisa",
  "description": "Complete Project"
}

### Update (ADMIN only)
PUT {{baseUrl}}/api/v1/project/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Updated Project",
  "description": "Complete Project"
}

### Delete (ADMIN only)
DELETE {{baseUrl}}/api/v1/project/1
Authorization: Bearer {{token}}


